---
import "../assets/css/style.css";
---

<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <title>엔드필드 숙제 관리</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Pretendard:wght@300;400;600;700;900&display=swap"
    />
  </head>
  <body
    class="relative min-h-screen overflow-x-hidden bg-slate-950 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-slate-800 via-slate-950 to-black pb-24 text-base text-slate-100 selection:bg-blue-500 selection:text-white"
  >
    <nav
      class="sticky top-0 z-50 flex justify-center gap-2 border-b border-white/5 bg-slate-900/90 p-2.5 backdrop-blur-md md:p-3"
    >
      <a
        href="/"
        class="rounded-xl bg-slate-800 px-3 py-2.5 text-xs font-bold text-slate-400 transition-all hover:bg-slate-700 hover:text-white md:px-5 md:text-base"
      >
        [CALC] 기질 계산
      </a>
      <a
        href="/todo"
        class="scale-105 rounded-xl bg-blue-600 px-3 py-2.5 text-xs font-bold text-white shadow-lg transition-all md:px-5 md:text-base"
      >
        [OPS] 업무 관리
      </a>
    </nav>

    <div
      class="mx-auto mt-3 max-w-3xl space-y-3 px-3 md:mt-6 md:space-y-6 md:px-8"
    >
      <section
        class="sticky top-[4.25rem] z-40 transition-all duration-300 md:top-20"
      >
        <div
          class="sticky-panel relative overflow-hidden rounded-2xl p-4 md:rounded-3xl md:p-6"
        >
          <div class="mb-3 flex items-start justify-between">
            <div>
              <h2
                class="flex items-center gap-2 text-lg font-bold text-white md:text-2xl"
              >
                <span class="h-5 w-1.5 rounded-full bg-blue-500 md:h-6 md:w-2"
                ></span> 일일 업무 보고
              </h2>
              <p
                class="mt-0.5 text-xs text-slate-400 md:text-sm"
                id="current-date"
              >
                로딩 중...
              </p>
            </div>
            <span class="text-3xl font-black text-blue-400 md:text-4xl"
              ><span id="progress-text">0</span>%</span
            >
          </div>

          <div
            class="mb-4 h-3 w-full overflow-hidden rounded-full border border-slate-700/50 bg-slate-800/50 md:h-4"
          >
            <div
              id="total-progress-bar"
              class="progress-bar h-3 w-0 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 shadow-[0_0_10px_#3b82f6] md:h-4"
            >
            </div>
          </div>

          <div
            class="flex flex-col gap-2 border-t border-white/10 pt-3 md:flex-row md:items-center md:justify-between"
          >
            <div class="flex w-full gap-2 md:w-auto">
              <div
                id="mode-switch-btn"
                class="mode-switch shrink-0"
                onclick="window.app.toggleViewMode()"
              >
                <div class="mode-switch-thumb"></div>
                <span class="mode-label" id="label-simple">간편</span>
                <span class="mode-label" id="label-detail">상세</span>
              </div>

              <button
                id="btn-toggle-completed"
                onclick="window.app.toggleHideCompleted()"
                class="flex flex-1 items-center justify-center gap-1.5 rounded-lg border border-slate-600 bg-slate-800 px-3 py-1.5 text-[11px] font-bold whitespace-nowrap text-slate-400 transition-colors hover:bg-slate-700 hover:text-white md:flex-none md:text-xs"
              >
                <span id="text-toggle-completed">완료 숨기기</span>
              </button>
            </div>

            <div class="grid w-full grid-cols-3 gap-2 md:flex md:w-auto">
              <button
                onclick="window.app.openHiddenManager()"
                class="rounded-lg border border-slate-600 bg-slate-800 px-3 py-1.5 text-[11px] font-bold whitespace-nowrap text-slate-400 transition-colors hover:bg-slate-700 hover:text-white md:text-xs"
              >
                EXCLUDE
              </button>

              <button
                onclick="window.app.resetOrder()"
                class="rounded-lg border border-slate-600 bg-slate-800 px-3 py-1.5 text-[11px] font-bold whitespace-nowrap text-slate-400 transition-colors hover:bg-slate-700 hover:text-white md:text-xs"
              >
                ORDER
              </button>

              <button
                onclick="window.app.forceReset()"
                class="rounded-lg border border-slate-600 bg-slate-800 px-3 py-1.5 text-[11px] font-bold whitespace-nowrap text-red-400 transition-colors hover:bg-slate-700 hover:text-red-300 md:text-xs"
              >
                RESET
              </button>
            </div>
          </div>
        </div>
      </section>

      <section id="task-list" class="min-h-[200px] space-y-0 pb-10"></section>

      <p
        class="pb-8 text-center text-[10px] text-slate-600"
        id="last-reset-time"
      >
        동기화 중...
      </p>
    </div>

    <div
      id="trash-zone"
      class="fixed top-0 right-0 bottom-0 z-[100] flex w-32 flex-col items-end justify-center pr-6"
    >
      <div
        class="animate-pulse text-4xl font-black drop-shadow-[0_0_10px_rgba(220,38,38,0.8)]"
      >
        DEL
      </div>
      <span
        class="mt-2 text-right text-sm leading-tight font-bold text-red-200 drop-shadow-md"
        >여기에<br />버리기</span
      >
    </div>

    <div
      id="hidden-modal-backdrop"
      class="fixed inset-0 z-[110] flex hidden items-center justify-center bg-black/90 p-3 backdrop-blur-md transition-opacity duration-200 md:p-4"
      onclick="window.app.closeHiddenManager()"
    >
      <div
        class="flex max-h-[80dvh] w-full max-w-lg flex-col rounded-2xl border border-slate-700 bg-slate-900 shadow-2xl md:max-h-[80vh] md:rounded-3xl"
        onclick="event.stopPropagation()"
      >
        <div
          class="flex items-center justify-between rounded-t-3xl border-b border-slate-800 bg-slate-800/50 p-5"
        >
          <h2 class="text-lg font-bold text-white md:text-xl">
            제외된 항목 관리
          </h2>
          <button
            onclick="window.app.closeHiddenManager()"
            class="text-2xl leading-none text-slate-400 hover:text-white"
            >&times;</button
          >
        </div>
        <div id="hidden-list" class="space-y-3 overflow-y-auto p-5"></div>
        <div class="rounded-b-3xl border-t border-slate-800 bg-slate-900 p-5">
          <button
            onclick="window.app.closeHiddenManager()"
            class="w-full rounded-xl bg-blue-600 py-3 text-sm font-bold text-white shadow-lg hover:bg-blue-500"
            >닫기</button
          >
        </div>
      </div>
    </div>
    <script>
      import "../main-todo.js";
    </script>
  </body>
</html>
